# Supabase — copy this file to .env.local and fill in your project credentials.
# Get these from: https://supabase.com/dashboard → Project Settings → API

# Public keys — safe to expose in browser bundles
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret — NEVER import this in client code ("use client" files)
SUPABASE_SERVICE_ROLE_KEY=
